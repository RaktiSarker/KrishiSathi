# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── MongoDB ─────────────────────────────────────────────────────────────────────
# Local development:
MONGO_URI=mongodb://localhost:27017/krishisathi
# For Vercel (production) — use MongoDB Atlas free tier:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/krishisathi?retryWrites=true&w=majority

# ── JWT Auth Secret ──────────────────────────────────────────────────────────────
# Use any long random string — keep secret!
JWT_SECRET=your_strong_random_secret_here

# ── Server Port (local dev only — Vercel ignores this) ───────────────────────────
SERVER_PORT=5000

# ── Frontend URL (for CORS in production) ────────────────────────────────────────
# Set this in Vercel dashboard to your Vercel app URL e.g. https://krishisathi.vercel.app
FRONTEND_URL=https://your-app.vercel.app
